SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_MIN_32_CHARS
ENVIRONMENT=production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
RESET_TOKEN_EXPIRE_MINUTES=30
PASSWORD_MIN_LENGTH=8
ENABLE_DOCS=false
EXPOSE_RESET_DEBUG_TOKEN=false
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=notifications@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM_EMAIL=notifications@example.com
SMTP_FROM_NAME=RSS Attendance System
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20
ENABLE_ATTENDANCE_REMINDER_SCHEDULER=true
ATTENDANCE_REMINDER_HOUR=9
ATTENDANCE_REMINDER_MINUTE=0
ATTENDANCE_REMINDER_TIMEZONE=Asia/Kolkata
CORS_ORIGINS=http://localhost,http://127.0.0.1
ADMIN_EMAIL=admin@rss.com
ADMIN_PASSWORD=Admin@123
# Seeded user role will be super_admin

MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_DATABASE=rss_db
# Optional override:
# DATABASE_URL=mysql+pymysql://root:password@db:3306/rss_db

GRAFANA_PASSWORD=grafana123
